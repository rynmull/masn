{
  "expo": {
    "name": "MASN",
    "slug": "masn-aac",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.masn.aac",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MASN can record your voice for custom sound effects on symbols if you choose.",
        "NSSpeechRecognitionUsageDescription": "MASN does not use speech recognition."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.masn.aac",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_APP_RESUME",
      "fallbackToCacheTimeout": 30000
    }
  }
}
